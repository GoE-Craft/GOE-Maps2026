{
    "format_version": "1.13.0",
    "minecraft:entity": {
      "description": {
        "identifier": "goe_tnt:button_yes",
        "is_spawnable": false,
        "is_summonable": true,
        "is_experimental": false
		},
    "component_groups": {
      "goe_tnt:pressed": {
        "minecraft:mark_variant": { "value": 1 },
        "minecraft:timer": {
          "time": 0.3,
          "looping": false,
          "time_down_event": { "event": "goe_tnt:reset" }
        }
      },
		  "goe_tnt:interact": {
            "minecraft:interact": {
                "interactions": [
                    { 
                      "on_interact": { "event": "goe_tnt:interact" },
                      "use_item": false, "interact_text": "Interact",
                      "swing": true
                    }
                ]
            }
        },
      "goe_tnt:damage_sensor":{
        "minecraft:damage_sensor": { "triggers": [{ "cause": "all", "deals_damage": false }] }
      },
      "goe_tnt:reset": {
        "minecraft:mark_variant": { "value": 0 }
      },
      "goe_tnt:hide": {
        "minecraft:mark_variant": { "value": 2 }
      }
    },
    "components": {
      "minecraft:mark_variant": { "value": 0 },
      "minecraft:fire_immune": {},
      "minecraft:type_family": { "family": [ "confirm_button", "furniture", "utility" ] },
      "minecraft:pushable": { "is_pushable": false, "is_pushable_by_piston": false },
      "minecraft:water_movement": { "drag_factor": 0.0 },
      "minecraft:push_through": {"value": 1},
      "minecraft:health": { "value": 30, "max": 30 },
      "minecraft:collision_box": { "width": 0.5, "height": 1.0 },
      "minecraft:knockback_resistance": { "value": 100, "max": 100 },
      "minecraft:physics": { "has_collision": false, "has_gravity": false }
    },
      "events": {
		  "minecraft:entity_spawned": {
			  "add": { "component_groups": [ "goe_tnt:interact", "goe_tnt:damage_sensor" ] },
        "queue_command": { 
          "command": [ 
            "playsound goe_tnt:button_error @a[r=10]"
          ] 
        }
		  },
		  "goe_tnt:interact": { 
				"remove": { "component_groups": [ "goe_tnt:interact", "goe_tnt:damage_sensor" ] },
				"add": { "component_groups": [ "goe_tnt:pressed" ] },
				"queue_command": { 
          "command": [
            "playsound goe_tnt:confirm_button @a[r=10]"
          ]
        } 
			},
      "goe_tnt:reset": {
        "remove": { "component_groups": [ "goe_tnt:pressed" ] },
			  "add": { "component_groups": [ "goe_tnt:reset" ] },
        "queue_command": { 
          "command": [
            "scriptevent goe_tnt:structure_button confirm"
          ]
        } 
		  },
      "goe_tnt:hide": {
        "remove": { "component_groups": [ "goe_tnt:pressed" ] },
        "add": { "component_groups": [ "goe_tnt:hide" ] }
      }
    }
  }
}