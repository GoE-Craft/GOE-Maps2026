{
    "format_version": "1.21.130",
    "minecraft:entity": {
        "description": {
            "identifier": "goe_tnt:matrix_tnt_child",
            "is_spawnable": false,
            "is_summonable": true
        },
        "component_groups": {
            "goe_tnt:spawn": {
                "minecraft:environment_sensor": {
                    "triggers": [
                        {
                            "event": "goe_tnt:spawned",
                            "target": "self",
                            "filters": {
                                "test": "on_ground"
                            }
                        }
                    ]
                }
            },
            "goe_tnt:active": {
                "minecraft:mark_variant": {
                    "value": 1
                },
                "minecraft:timer": {
                    "time": 2.21,
                    "looping": true,
                    "time_down_event": {
                        "event": "goe_tnt:activate",
                        "target": "self"
                    }
                }
            },
            "goe_tnt:wander": {
                "minecraft:movement": {
                    "value": 0.4,
                    "max": 0.4
                },
                "minecraft:movement.basic": {
                    "max_turn": 360
                },
                "minecraft:navigation.walk": {
                    "avoid_damage_blocks": true,
                    "can_pass_doors": true,
                    "can_jump": true
                },
                "minecraft:behavior.move_to_random_block": {
                    "block_distance": 10,
                    "within_radius": 3,
                    "priority": 1
                },
                "minecraft:mark_variant": {
                    "value": 2
                },
                "minecraft:explode": {
                    "causes_fire": false,
                    "destroy_affected_by_griefing": true,
                    "fuse_lit": true,
                    "fuse_length": [
                        2,
                        3
                    ],
                    "power": 2
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [ "custom_tnt", "inanimate" ]
            },
            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "cause": "all",
                        "deals_damage": "no"
                    }
                ]
            },
            "minecraft:health": {
                "value": 1,
                "max": 1
            },
            "minecraft:renders_when_invisible": {},
            "minecraft:physics": {
                "has_collision": true,
                "has_gravity": true
            },
            "minecraft:pushable": { "is_pushable": false, "is_pushable_by_piston": false },  
            "minecraft:collision_box": {
                "height": 0.3,
                "width": 0.3
            },
            "minecraft:conditional_bandwidth_optimization": {
                "default_values": {
                    "max_optimized_distance": 80.0,
                    "max_dropped_ticks": 1,
                    "use_motion_prediction_hints": true
                }
            }
        },
        "events": {
            "minecraft:entity_spawned":{
                "add": {
                    "component_groups": [
                        "goe_tnt:spawn"
                    ]
                }
            },
            "goe_tnt:spawned": {
                "queue_command": {"command":"say Spawned!"},
                "add": {
                    "component_groups": [
                        "goe_tnt:active"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "goe_tnt:spawn"
                    ]
                }
            },
            "goe_tnt:activate": {
                "queue_command": {"command":"say Activate!"},
                "add": {
                    "component_groups": [
                        "goe_tnt:wander"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "goe_tnt:active"
                    ]
                }
            }
        }
    }
}