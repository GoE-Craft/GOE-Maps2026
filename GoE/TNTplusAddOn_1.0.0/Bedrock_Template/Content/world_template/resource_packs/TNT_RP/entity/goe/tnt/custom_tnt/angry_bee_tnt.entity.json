{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:angry_bee_tnt",
      "materials": {
        "default": "entity_alphatest",
        "boost_level": "goe_tnt_additive"
      },
      "textures": {
        "default": "textures/goe/tnt/entity/angry_bee_tnt"
      },
      "geometry": {
        "default": "geometry.angry_bee_tnt",
        "boost_level": "geometry.angry_bee_tnt_boost_level"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');"
        ],
        "animate": [
          {"charge": "q.mark_variant == 1"},
          {"explode": "q.mark_variant == 2"},
          {"boost_scale": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "charge": "animation.angry_bee_tnt.charge",
        "explode": "animation.angry_bee_tnt.explode",
        "boost_scale": "animation.tnt.boost_scale"
      },
      "particle_effects": {
        "one_big_puff": "goe_tnt:one_big_puff",
        "tnt_charge_yellow": "goe_tnt:tnt_charge_yellow",
        "yellow_poof": "goe_tnt:yellow_poof",
        "honey_splatter": "goe_tnt:honey_splatter",
        "yellow_bubble": "goe_tnt:yellow_bubble"
      },    
      "render_controllers": [ 
        "controller.render.tnt",
        {"controller.render.tnt_boost_scale": "v.boost_scale > 1"}
      ]
    }
  }
}