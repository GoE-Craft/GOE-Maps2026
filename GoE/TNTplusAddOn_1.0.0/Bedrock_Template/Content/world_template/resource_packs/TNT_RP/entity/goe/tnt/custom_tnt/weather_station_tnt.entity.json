{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:weather_station_tnt",
      "materials": {
        "default": "entity_alphatest",
        "boost_level": "goe_tnt_additive"
      },
      "textures": {
        "default": "textures/goe/tnt/entity/weather_station_tnt"
      },
      "geometry": {
        "default": "geometry.weather_station_tnt",
        "boost_level": "geometry.weather_station_tnt_boost_level"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.raining = q.property('goe_tnt:is_raining');",
          "v.boost_scale = 1 + (q.property('goe_tnt:boost_level') * 0.05);"
        ],
        "animate": [
          {"tnt_swelling": "q.mark_variant == 1"},
          {"charge": "q.mark_variant == 1 && !v.raining"},
          {"charge_sun": "q.mark_variant == 1 && v.raining"},
          {"explode": "q.mark_variant == 2 && !v.raining"},
          {"explode_sun": "q.mark_variant == 2 && v.raining"},
          {"boost_scale": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "tnt_swelling": "animation.tnt.swell_weather_rain",
        "charge": "animation.weather_tnt.charge_rain",
        "charge_sun": "animation.weather_tnt.charge_sun",
        "explode":"animation.weather_tnt.explode_rain",
        "explode_sun":"animation.weather_tnt.explode_sun",
        "boost_scale": "animation.tnt.boost_scale"
      },
        "particle_effects": {
        "weather_rain": "goe_tnt:weather_rain",
        "weather_rain_explode": "goe_tnt:weather_rain_explode",
        "weather_rain_fall": "goe_tnt:weather_rain_fall",
        "weather_ring": "goe_tnt:weather_ring",
        "weather_sun": "goe_tnt:weather_sun",
        "weather_sun_explode": "goe_tnt:weather_sun_explode",
        "weather_sun_fall": "goe_tnt:weather_sun_fall",
        "tnt_charge_blue": "goe_tnt:tnt_charge_blue"
      },
      "render_controllers": [ "controller.render.tnt", "controller.render.tnt_boost_scale" ]
    }
  }
}