{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:teleportation_tnt",
      "materials": {
        "default": "entity_alphatest",
        "glass": "entity_alphablend",
        "boost_level": "goe_tnt_additive"
      },
      "textures": {
        "default": "textures/goe/tnt/entity/teleportation_tnt"
      },
      "geometry": {
        "default": "geometry.teleportation_tnt",
        "boost_level": "geometry.teleportation_tnt_boost_level"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');"
        ],
        "animate": [
          {"tnt_swelling": "q.mark_variant == 1 || v.should_swell"},
          {"charge": "q.mark_variant == 1"},
          {"boost_scale": "v.boost_scale > 1"}
          //{"explode": "q.mark_variant == 2"}
        ]
			},
      "animations": {
        "tnt_swelling": "animation.teleportation_tnt.swell",
        "charge": "animation.teleportation_tnt.charge",
        "boost_scale": "animation.tnt.boost_scale"
        //"explode": ""
      },
      "particle_effects": {
        "matrix_effect": "goe_tnt:matrix_effect",
        "tnt_charge_matrix_blue": "goe_tnt:tnt_charge_matrix_blue",
        "tnt_charge_blue": "goe_tnt:tnt_charge_blue"
      },
      "render_controllers": [ 
        "controller.render.teleportation_tnt",
        {"controller.render.tnt_boost_scale": "v.boost_scale > 1"}
      ]
    }
  }
}