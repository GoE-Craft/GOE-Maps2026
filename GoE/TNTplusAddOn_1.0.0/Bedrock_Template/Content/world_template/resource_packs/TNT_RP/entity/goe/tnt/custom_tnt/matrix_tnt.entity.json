{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "goe_tnt:matrix_tnt",
            "materials": { "default": "entity_alphatest", "boost_level": "goe_tnt_additive" },
            "textures": { "default": "textures/goe/tnt/entity/matrix_tnt" },
            "geometry": { 
                "default": "geometry.matrix_tnt", 
                "boost_level": "geometry.matrix_tnt_boost_level" 
            },
            "scripts": {
                "animate": [
                    { "charge": "q.mark_variant == 1" }, 
                    { "explosion": "q.mark_variant == 2" }, 
                    { "boost_scale": "v.boost_scale > 1" }
                ],
                "pre_animation": [
                    "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');"
                ]
            },
            "animations": { 
                "charge": "animation.matrix_tnt.charge", 
                "explosion": "animation.matrix_tnt.split", 
                "boost_scale": "animation.tnt.boost_scale" 
            },
            "particle_effects": { "detonator_impact_green": "goe_tnt:detonator_impact_green", "matrix_explode": "goe_tnt:matrix_explode" },
            "render_controllers": ["controller.render.tnt", { "controller.render.tnt_boost_scale": "v.boost_scale > 1" }]
        }
    }
}
