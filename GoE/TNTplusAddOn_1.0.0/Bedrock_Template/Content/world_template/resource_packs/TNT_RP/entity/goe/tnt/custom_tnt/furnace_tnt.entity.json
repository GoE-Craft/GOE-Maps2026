{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:furnace_tnt",
      "materials": {
        "default": "entity_alphatest",
        "boost_level": "goe_tnt_additive"
      },
      "textures": {
				"default": "textures/goe/tnt/entity/furnace_tnt"
      },
      "geometry": {
				"default": "geometry.furnace_tnt",
        "boost_level": "geometry.furnace_tnt_boost_level"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');"
        ],
        "animate": [
          {"charge": "q.mark_variant == 1"},
          {"explode": "q.mark_variant == 2"},
          {"boost_scale": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "explode":"animation.furnace_tnt.explode",
        "charge":"animation.furnace_tnt.charge",
        "boost_scale": "animation.tnt.boost_scale"
      },
       "particle_effects": {
        "furnace_explode": "goe_tnt:furnace_explode",
        "furnace_fire": "goe_tnt:furnace_fire",
        "furnace_pull": "goe_tnt:furnace_pull",
        "furnace_smoke": "goe_tnt:furnace_smoke",
        "tnt_charge_red": "goe_tnt:tnt_charge_red"
      },
      "render_controllers": [ 
        "controller.render.tnt",
        {"controller.render.tnt_boost_scale": "v.boost_scale > 1"}
      ]
    }
  }
}