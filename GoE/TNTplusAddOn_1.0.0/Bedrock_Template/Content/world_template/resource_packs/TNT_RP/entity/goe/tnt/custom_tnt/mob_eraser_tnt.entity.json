{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:mob_eraser_tnt",
      "materials": {
        "default": "entity_alphatest",
        "overlay_tnt": "charged_creeper"
      },
      "textures": {
        //Boost Level Textures
        "boost_level_0": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_1": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_2": "textures/goe/tnt/entity/boost_level_2",
        "boost_level_3": "textures/goe/tnt/entity/boost_level_3",
        "boost_level_4": "textures/goe/tnt/entity/boost_level_4",

        //TNT Texture
				"default": "textures/goe/tnt/entity/mob_eraser_tnt"
      },
      "geometry": {
        "default": "geometry.mob_eraser_tnt",
        "overlay_tnt": "geometry.overlay_mob_eraser_tnt"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');",
          "v.anim_speed = (query.property('goe_tnt:boost_level') == 0) ? 0.013 : ((query.property('goe_tnt:boost_level') == 1) ? 0.013: ((query.property('goe_tnt:boost_level') == 2) ? 0.03 : ((query.property('goe_tnt:boost_level') == 3) ? 0.04 : 0.04)));",
          "v.anim_overlay = (query.property('goe_tnt:boost_level') == 0) ? 1.8 : ((query.property('goe_tnt:boost_level') == 1) ? 1.8: ((query.property('goe_tnt:boost_level') == 2) ? 1.55 : ((query.property('goe_tnt:boost_level') == 3) ? 1.2 : 0.6)));"
        ],
        "animate": [
          {"charge": "q.mark_variant == 1"},
          {"explode": "q.mark_variant == 2"},
          {"overlay_size": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "charge": "animation.mob_eraser_tnt.charge",
        "explode": "animation.mob_eraser_tnt.explode",
        "overlay_size": "animation.tnt.overlay_size"
      },
      "particle_effects": {
        "mob_eraser_explosion": "goe_tnt:mob_eraser_explosion",
        "mob_eraser_explosion_pull": "goe_tnt:mob_eraser_explosion_pull",
        "mob_heads": "goe_tnt:mob_heads",
        "mob_heads_pull": "goe_tnt:mob_heads_pull",
        "tnt_charge_colors": "goe_tnt:tnt_charge_colors",
        "mob_eraser_impact": "goe_tnt:mob_eraser_impact",
        "mob_eraser_impact_pull": "goe_tnt:mob_eraser_impact_pull",
        "mob_destroy": "goe_tnt:mob_destroy",
        "party_sparks": "goe_tnt:party_sparks"
      },
      "render_controllers": [ 
        "controller.render.tnt",
        {"controller.render.tnt_boost_scale": "v.boost_scale > 1"}
      ]
    }
  }
}