{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:thief_tnt",
      "materials": {
        "default": "entity_alphatest",
        "boost_level": "goe_tnt_additive"
      },
      "textures": {
        "default": "textures/goe/tnt/entity/thief_tnt"
      },
      "geometry": {
        "default": "geometry.thief_tnt",
        "boost_level": "geometry.thief_tnt_boost_level"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');"
        ],
        "animate": [
          {"tnt_swelling": "q.mark_variant == 1"},
          {"charge": "q.mark_variant == 1"},
          {"explosion" : "q.mark_variant == 2"},
          {"boost_scale": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "tnt_swelling": "animation.thief_tnt.swell",
        "charge" : "animation.thief_tnt.charge",
        "explosion" : "animation.thief_tnt.explosion",
        "boost_scale": "animation.tnt.boost_scale"
      },
      "particle_effects": {
        "tnt_charge": "goe_tnt:tnt_charge_purple",
        "thief_fountain": "goe_tnt:thief_fountain",
        "thief_fog": "goe_tnt:thief_fog",
        "puff_purple": "goe_tnt:one_big_puff_puple",
        "thief_implosion": "goe_tnt:thief_implosion",
        "mask": "goe_tnt:thief_mask",
        "explosion_purple": "goe_tnt:big_explosion_purple"
      },
      "render_controllers": [ 
        "controller.render.tnt",
        {"controller.render.tnt_boost_scale": "v.boost_scale > 1"}
      ]
    }
  }
}