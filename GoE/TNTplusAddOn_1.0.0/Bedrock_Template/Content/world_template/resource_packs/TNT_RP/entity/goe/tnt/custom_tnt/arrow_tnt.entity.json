{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:arrow_tnt",
      "materials": {
        "default": "entity_alphatest",
        "boost_level": "goe_tnt_additive"
      },
      "textures": {
        "default": "textures/goe/tnt/entity/arrow_tnt"
      },
      "geometry": {
        "default": "geometry.arrow_tnt",
        "boost_level": "geometry.arrow_tnt_boost_level"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
				  "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');"
        ],
        "animate": [
          {"charge": "q.mark_variant == 1"},
          {"explode": "q.mark_variant == 2"},
					{"boost_scale": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "tnt_swelling": "animation.tnt.swell_arrow",
        "explode":"animation.arrow_tnt.explode",
        "charge":"animation.arrow_tnt.charge",
				"boost_scale": "animation.tnt.boost_scale"
      },
       "particle_effects": {
        "arrow_explode": "goe_tnt:arrow_explode",
        "tnt_charge_red": "goe_tnt:tnt_charge_red"
       
      },
      "render_controllers": [ 
          "controller.render.tnt",  
          {	"controller.render.tnt_boost_scale": "v.boost_scale > 1" }  
      ]
    }
  }
}