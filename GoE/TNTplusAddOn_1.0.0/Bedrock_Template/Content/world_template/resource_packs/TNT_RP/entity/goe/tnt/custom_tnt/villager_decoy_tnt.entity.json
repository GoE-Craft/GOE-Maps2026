{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:villager_decoy_tnt",
      "materials": {
        "default": "entity_alphatest",
        "boost_level": "goe_tnt_additive"
      },
      "textures": {
        "default": "textures/goe/tnt/entity/villager_decoy_tnt"
      },
      "geometry": {
        "default": "geometry.villager_decoy_tnt",
        "boost_level": "geometry.villager_decoy_tnt_boost_level"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');"
        ],
        "animate": [
          {"charge": "q.mark_variant == 1"},
          {"explode": "q.mark_variant == 2"},
          {"boost_scale": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "charge": "animation.villager_decoy_tnt.charge",
        "explode": "animation.villager_decoy_tnt.explode",
        "boost_scale": "animation.tnt.boost_scale"
      },
      "particle_effects": {
        "big_explosion_red": "goe_tnt:big_explosion_red",
        "tnt_charge_red": "goe_tnt:tnt_charge_red",
        "tnt_charge_red_small": "goe_tnt:tnt_charge_red_small"
      },      
      "render_controllers": [
        "controller.render.tnt",
        {"controller.render.tnt_boost_scale": "v.boost_scale > 1"}
      ]
    }
  }
}