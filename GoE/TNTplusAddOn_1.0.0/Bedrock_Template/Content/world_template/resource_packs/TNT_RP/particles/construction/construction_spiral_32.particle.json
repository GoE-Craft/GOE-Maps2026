{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "goe_tnt:construction_spiral_32",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/goe/tnt/particles/button_particle"
			}
		},
		"curves": {
			"variable.g": {
				"type": "linear",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [0, 1, 0]
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "variable.size = 0.45;variable.radius = 20;v.time = 0;v.height = 13;",
				"per_update_expression": "v.time = v.time + 0.05;"
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 400,
				"max_particles": 2000
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 3
			},
			"minecraft:emitter_shape_disc": {
				"offset": ["math.cos(v.time*360) * v.radius", "v.emitter_age * v.height + 3 + math.random(-3, 3)", "math.sin(v.time*360) * v.radius"],
				"radius": "(8 - (v.emitter_age * 2)) * 2",
				"plane_normal": "y",
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 0.8
			},
			"minecraft:particle_initial_spin": {
				"rotation": 40,
				"rotation_rate": 120
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": ["(variable.size*(2-variable.particle_age)*1) *v.g", "(variable.size*(2-variable.particle_age)*1)*v.g"],
				"facing_camera_mode": "rotate_xyz"
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFF8000",
						"0.5": "#ffffffff",
						"1.0": "#FFFFB700"
					}
				}
			}
		}
	}
}