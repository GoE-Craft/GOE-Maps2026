{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "goe_tnt:black_hole_ring",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/goe/tnt/particles/light_fog"
			}
		},
		"curves": {
			"variable.stretch": {
				"type": "linear",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [0, 1, 0, 0]
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 700,
				"max_particles": 700
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_disc": {
				"radius": 2,
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 4.5
			},
			"minecraft:particle_motion_parametric": {
				"relative_position": ["Math.cos((variable.particle_age * 360) + (variable.particle_random_1 * 360))*8*variable.stretch", 0, "Math.sin((variable.particle_age * 360) + (variable.particle_random_1 * 360))*8*variable.stretch"],
				"direction": [0, 1, 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": [0.5, 0.5],
				"facing_camera_mode": "rotate_xyz"
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#00FFFFFF",
						"0.05": "#6BFFFFFF",
						"0.57": "#66FFFFFF",
						"0.65": "#00FFFFFF"
					}
				}
			}
		}
	}
}