{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:weather_station_tnt",
      "materials": {
        "default": "entity_alphatest",
        "overlay_tnt": "charged_creeper"
      },
      "textures": {
        //Boost Level Textures
        "boost_level_0": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_1": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_2": "textures/goe/tnt/entity/boost_level_2",
        "boost_level_3": "textures/goe/tnt/entity/boost_level_3",
        "boost_level_4": "textures/goe/tnt/entity/boost_level_4",

        //TNT Texture
				"default": "textures/goe/tnt/entity/weather_station_tnt"
      },
      "geometry": {
        "default": "geometry.weather_station_tnt",
        "overlay_tnt": "geometry.overlay_weather_station_tnt"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.raining = q.property('goe_tnt:is_raining');",
          "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');",
          "v.anim_speed = (query.property('goe_tnt:boost_level') == 0) ? 0.013 : ((query.property('goe_tnt:boost_level') == 1) ? 0.013: ((query.property('goe_tnt:boost_level') == 2) ? 0.03 : ((query.property('goe_tnt:boost_level') == 3) ? 0.04 : 0.04)));",
          "v.anim_overlay = (query.property('goe_tnt:boost_level') == 0) ? 1.8 : ((query.property('goe_tnt:boost_level') == 1) ? 1.8: ((query.property('goe_tnt:boost_level') == 2) ? 1.55 : ((query.property('goe_tnt:boost_level') == 3) ? 1.2 : 0.6)));"
        ],
        "animate": [
          {"tnt_swelling": "q.mark_variant == 1"},
          {"charge": "q.mark_variant == 1 && !v.raining"},
          {"charge_sun": "q.mark_variant == 1 && v.raining"},
          {"explode": "q.mark_variant == 2 && !v.raining"},
          {"explode_sun": "q.mark_variant == 2 && v.raining"},
          {"overlay_size": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "tnt_swelling": "animation.goe_tnt.tnt.swell_weather_rain",
        "charge": "animation.goe_tnt.weather_tnt.charge_rain",
        "charge_sun": "animation.goe_tnt.weather_tnt.charge_sun",
        "explode":"animation.goe_tnt.weather_tnt.explode_rain",
        "explode_sun":"animation.goe_tnt.weather_tnt.explode_sun",
        "overlay_size": "animation.goe_tnt.tnt.overlay_size"
      },
        "particle_effects": {
        "weather_rain": "goe_tnt:weather_rain",
        "weather_rain_explode": "goe_tnt:weather_rain_explode",
        "weather_rain_fall": "goe_tnt:weather_rain_fall",
        "weather_ring": "goe_tnt:weather_ring",
        "weather_sun": "goe_tnt:weather_sun",
        "weather_sun_explode": "goe_tnt:weather_sun_explode",
        "weather_sun_fall": "goe_tnt:weather_sun_fall",
        "tnt_charge_blue": "goe_tnt:tnt_charge_blue"
      },
      "render_controllers": [ 
        "controller.render.goe_tnt.tnt", 
        {"controller.render.goe_tnt.tnt_boost_scale": "v.boost_scale > 1"}
      ]
    }
  }
}