{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:endermite_decoy_tnt",
      "materials": {
        "default": "entity_alphatest",
        "alphatest": "entity_alphatest",
        "transparent": "entity_beam_additive",
        "overlay_tnt": "charged_creeper"
      },
      "textures": {
        //Boost Level Textures
        "boost_level_0": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_1": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_2": "textures/goe/tnt/entity/boost_level_2",
        "boost_level_3": "textures/goe/tnt/entity/boost_level_3",
        "boost_level_4": "textures/goe/tnt/entity/boost_level_4",

        //TNT Texture
				"default": "textures/goe/tnt/entity/endermite_decoy_tnt"
      },
      "geometry": {
        "default": "geometry.endermite_decoy_tnt",
        "overlay_tnt": "geometry.overlay_endermite_decoy_tnt"
      },
			"scripts": {
        "pre_animation": [
          				  "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');",
          "v.anim_speed = (query.property('goe_tnt:boost_level') == 0) ? 0.013 : ((query.property('goe_tnt:boost_level') == 1) ? 0.013: ((query.property('goe_tnt:boost_level') == 2) ? 0.03 : ((query.property('goe_tnt:boost_level') == 3) ? 0.04 : 0.04)));",
          "v.anim_overlay = (query.property('goe_tnt:boost_level') == 0) ? 1.8 : ((query.property('goe_tnt:boost_level') == 1) ? 1.8: ((query.property('goe_tnt:boost_level') == 2) ? 1.55 : ((query.property('goe_tnt:boost_level') == 3) ? 1.2 : 0.6)));"
        ],
        "animate": [
          {"charge": "q.mark_variant == 1"},
          {"explode": "q.mark_variant == 2"},
          {"overlay_size": "v.boost_scale > 1"}
        ]
			},
      "animations": {
        "tnt_swelling": "animation.goe_tnt.endermite_decoy_tnt.swell",
        "charge": "animation.goe_tnt.endermite_decoy_tnt.charge",
        "explode": "animation.goe_tnt.endermite_decoy_tnt.explode",
        "overlay_size": "animation.goe_tnt.tnt.overlay_size"
      },
      "particle_effects": {
        "ender_sparkle_pink": "goe_tnt:ender_sparkle_pink",
        "ender_sparkle": "goe_tnt:ender_sparkle",
        "tnt_charge_purple": "goe_tnt:tnt_charge_purple",
        "ender_fog": "goe_tnt:ender_fog",
        "ender_effect": "goe_tnt:ender_effect",
        "ender_sparkle_explosion": "goe_tnt:ender_sparkle_explosion",
        "enderman": "goe_tnt:enderman",
        "enderman2": "goe_tnt:enderman2"
      },
      "render_controllers": [ 
        "controller.render.goe_tnt.endermite_decoy_tnt",
        {"controller.render.goe_tnt.tnt_boost_scale": "v.boost_scale > 1"}
      ]
    }
  }
}