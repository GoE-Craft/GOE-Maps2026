{
	"format_version" : "1.10.0",
	"animation_controllers" : {
		"controller.animation.goe_tnt.tnt_detonator" : {
			"initial_state" : "default",
			"states" : {
				"default" : {
					"transitions": [
            {"push": "q.cooldown_time_remaining('item_use') > 0"}
          ]
				},
				"push" : {
					"animations" : [ 
						"push", 
						"push_wave",
						"push_pulse"
					],
					"transitions" : [
						{ "default": "q.cooldown_time_remaining('item_use') <= 0 && q.all_animations_finished" }
					]
				}
			}
		}
	}
}
