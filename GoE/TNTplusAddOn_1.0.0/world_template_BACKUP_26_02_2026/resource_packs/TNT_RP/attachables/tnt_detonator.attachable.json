{
	"format_version": "1.10.0",
	"minecraft:attachable": {
		"description": {
			"identifier": "goe_tnt:tnt_detonator",
			"render_controllers": ["controller.render.goe_tnt.tnt_detonator"],
			"materials": {
				"default": "entity_alphatest",
				"enchanted": "entity_alphatest_glint",
				"signal" : "entity_alphablend"
			},
			"textures": {
				"default": "textures/goe/tnt/items/tnt_detonator/tnt_detonator",
				"enchanted": "textures/misc/enchanted_item_glint"
			},
			"geometry": {
				"default": "geometry.tnt_detonator"
			},
			"animations": {
