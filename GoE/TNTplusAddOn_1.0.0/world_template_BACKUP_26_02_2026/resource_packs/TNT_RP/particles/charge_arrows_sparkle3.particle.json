{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "goe_tnt:charge_arrows_sparkle_3",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/goe/tnt/particles/ender_sparkle"
			}
		},
		"curves": {
			"variable.transparency": {
				"type": "catmull_rom",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [0, 1, 0, 1, 0, 1, 0, 1, 0]
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "variable.size = 0.03;variable.lifetime = 2.2;"
			},
			"minecraft:emitter_rate_manual": {
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 4
			},
			"minecraft:emitter_shape_sphere": {
				"offset": ["0-variable.particle_age", "0.25+variable.particle_age", "0-variable.particle_age"],
				"radius": 2,
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.clamp(variable.particle_random_1*variable.lifetime, 0.5, 2)"
			},
			"minecraft:particle_expire_if_not_in_blocks": ["minecraft:air"],
			"minecraft:particle_initial_speed": "0.6-variable.particle_age",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": ["0.5-variable.particle_age", "0.5+variable.particle_age", "0.5-variable.particle_age"],
				"linear_drag_coefficient": "0.2+variable.particle_age"
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.size*(variable.lifetime-variable.particle_age)*variable.transparency * 2 ", "variable.size*(variable.lifetime-variable.particle_age)*variable.transparency * 2"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 256,
					"texture_height": 32,
					"flipbook": {
						"base_UV": [0, 0],
						"size_UV": [32, 32],
						"step_UV": [32, 0],
						"frames_per_second": 2,
						"max_frame": 8,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "(variable.particle_random_1*variable.particle_age)",
					"gradient": {
						"0.0": "#87FF2C2C",
						"0.25": "#FFFFBCBC",
						"0.49": "#87FF3C3C",
						"0.74": "#FFFFBCBC",
						"1.0": "#87FF3E3E"
					}
				}
			}
		}
	}
}