{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "goe_tnt:daytime_tnt",
      "materials": {
        "default": "entity_alphatest",
        "beam_day": "entity_beam_additive",
        "beam_night": "entity_beam_additive",
        "semitransparent_1": "entity_alphablend",
        "semitransparent_2": "entity_alphablend",
        "semitransparent_3": "entity_alphablend",
        "overlay_tnt": "charged_creeper"
      },
      "textures": {
        //Boost Level Textures
        "boost_level_0": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_1": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_2": "textures/goe/tnt/entity/boost_level_2",
        "boost_level_3": "textures/goe/tnt/entity/boost_level_3",
        "boost_level_4": "textures/goe/tnt/entity/boost_level_4",

        //TNT Texture
				"default": "textures/goe/tnt/entity/daytime_tnt"
      },
      "geometry": {
        "default": "geometry.daytime_tnt",
        "overlay_tnt": "geometry.overlay_daytime_tnt"
      },
			"scripts": {
        "pre_animation": [
          "v.should_swell = query.property('goe_tnt:swell');",
          				  "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');",
          "v.anim_speed = (query.property('goe_tnt:boost_level') == 0) ? 0.013 : ((query.property('goe_tnt:boost_level') == 1) ? 0.013: ((query.property('goe_tnt:boost_level') == 2) ? 0.03 : ((query.property('goe_tnt:boost_level') == 3) ? 0.04 : 0.04)));",
          "v.anim_overlay = (query.property('goe_tnt:boost_level') == 0) ? 1.8 : ((query.property('goe_tnt:boost_level') == 1) ? 1.8: ((query.property('goe_tnt:boost_level') == 2) ? 1.55 : ((query.property('goe_tnt:boost_level') == 3) ? 1.2 : 0.6)));"
        ],
        "animate": [
          {"tnt_swelling": "q.mark_variant == 1"},
          {"charge": "q.mark_variant == 1"},
          {"explode": "q.mark_variant == 2"},
          "overlay_size"
        ]
			},
      "animations": {
        "tnt_swelling": "animation.goe_tnt.tnt.swell_daytime_night",
        "charge": "animation.goe_tnt.daytime_tnt.charge_night",
        "charge_day": "animation.goe_tnt.daytime_tnt.charge_day",
        "explode": "animation.goe_tnt.daytime_tnt.explode_night",
        "explode_day": "animation.goe_tnt.daytime_tnt.explode_day",
        "overlay_size": "animation.goe_tnt.tnt.overlay_size"
      },
       "particle_effects": {
        "daytime_day": "goe_tnt:daytime_day",
        "daytime_explode_day": "goe_tnt:daytime_explode_day",
        "daytime_explode_night": "goe_tnt:daytime_explode_night",
        "daytime_night": "goe_tnt:daytime_night",
        "daytime_pull_day": "goe_tnt:daytime_pull_day",
        "daytime_pull_night": "goe_tnt:daytime_pull_night",
        "daytime_ring_day": "goe_tnt:daytime_ring_day",
        "daytime_ring_night": "goe_tnt:daytime_ring_night",
        "daytime_rotate_day": "goe_tnt:daytime_rotate_day",
        "daytime_rotate_night": "goe_tnt:daytime_rotate_night",
        "daytime_smoke": "goe_tnt:daytime_smoke",
        "daytime_impact_day": "goe_tnt:daytime_impact_day",
        "daytime_impact_night": "goe_tnt:daytime_impact_night",
        "daytime_impact_radius_day": "goe_tnt:daytime_impact_radius_day",
        "daytime_impact_radius_night": "goe_tnt:daytime_impact_radius_night",
        "ground_shake": "goe_tnt:ground_shake",
        "tnt_charge_darkblue": "goe_tnt:tnt_charge_darkblue",
        "tnt_charge_yellow": "goe_tnt:tnt_charge_yellow"
       
      }, 
      "render_controllers": [
        "controller.render.goe_tnt.daytime_tnt",
        {"controller.render.goe_tnt.tnt_boost_scale": "query.property('goe_tnt:boost_level') > 0"}
      ]
    }
  }
}