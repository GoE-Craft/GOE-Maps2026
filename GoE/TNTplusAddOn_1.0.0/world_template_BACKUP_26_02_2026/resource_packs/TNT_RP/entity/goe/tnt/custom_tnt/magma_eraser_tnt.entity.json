{
  "format_version":"1.10.0",
  "minecraft:client_entity":{
    "description":{
      "identifier":"goe_tnt:magma_eraser_tnt",
      "materials":{
        "default":"entity_alphatest",
        "beam":"goe_tnt_border",
        "overlay_tnt":"charged_creeper"
      },
      "textures":{      
        //Boost Level Textures
        "boost_level_0": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_1": "textures/goe/tnt/entity/boost_level_1",
        "boost_level_2": "textures/goe/tnt/entity/boost_level_2",
        "boost_level_3": "textures/goe/tnt/entity/boost_level_3",
        "boost_level_4": "textures/goe/tnt/entity/boost_level_4",

        //TNT Texture
        "default":"textures/goe/tnt/entity/eruption_tnt"
      },
      "geometry":{
        "default":"geometry.eruption_tnt",
        "overlay_tnt":"geometry.overlay_eruption_tnt"
      },
      "scripts":{
        "pre_animation":[
          "v.should_swell = query.property('goe_tnt:swell');",
          "v.boost_scale = 1 + 0.1 * query.property('goe_tnt:boost_level');",
          "v.anim_speed = (query.property('goe_tnt:boost_level') == 0) ? 0.013 : ((query.property('goe_tnt:boost_level') == 1) ? 0.013: ((query.property('goe_tnt:boost_level') == 2) ? 0.03 : ((query.property('goe_tnt:boost_level') == 3) ? 0.04 : 0.04)));",
          "v.anim_overlay = (query.property('goe_tnt:boost_level') == 0) ? 1.8 : ((query.property('goe_tnt:boost_level') == 1) ? 1.8: ((query.property('goe_tnt:boost_level') == 2) ? 1.55 : ((query.property('goe_tnt:boost_level') == 3) ? 1.2 : 0.6)));"
        ],
        "animate":[
          {"tnt_swelling":"q.mark_variant == 1"},
          {"charge":"q.mark_variant == 1"},
          {"explosion":"q.mark_variant == 2"},
          {"overlay_size":"v.boost_scale > 1"}
        ]
      },
      "animations":{
        "tnt_swelling":"animation.goe_tnt.magma_eraser_tnt.swell",
        "charge":"animation.goe_tnt.magma_eraser_tnt.charge",
        "explosion":"animation.goe_tnt.magma_eraser_tnt.explosion",
        "overlay_size":"animation.goe_tnt.tnt.boost_scale"
      },
      "particle_effects":{
        "tnt_charge_yellow":"goe_tnt:tnt_charge_yellow",
        "collapsing_lines_orange":"goe_tnt:collapsing_lines_orange",
        "eruption":"goe_tnt:magma_eraser_eruption",
        "pull":"goe_tnt:eraser_pull",
        "pull_stone":"goe_tnt:eraser_pull_stone",
        "atmosphere_impact_orange":"goe_tnt:atmosphere_impact_orange",
        "atmosphere_impact_orange_reverse":"goe_tnt:atmosphere_impact_orange_reverse",
        "explosion_particle":"goe_tnt:magma_eraser_explosion",
        "stone_explosion":"goe_tnt:magma_eraser_stone_explosion",
        "one_big_puff":"goe_tnt:one_big_puff_orange",
        "implosion":"goe_tnt:magma_eraser_implosion",
        "smoke":"goe_tnt:magma_smoke"
      },
      "render_controllers":[
        "controller.render.goe_tnt.healing_tnt",
        {"controller.render.goe_tnt.tnt_boost_scale":"v.boost_scale > 1"}
      ]
    }
  }
}
